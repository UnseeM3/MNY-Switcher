{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MNY Switcher",
  "version": "0.1.0",
  "identifier": "com.mny.switcher",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MNY Switcher",
        "width": 400,
        "height": 500,
        "resizable": false,
        "maximizable": false,
        "minimizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Unsee",
    "copyright": "Copyright (c) 2026 Unsee",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
